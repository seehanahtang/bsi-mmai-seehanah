    "!pip -q install datasets huggingface_hub\n",
    "\n",
    "import os, json\n",
    "from pathlib import Path\n",
    "from datasets import load_dataset\n",
    "from huggingface_hub import login\n",
    "\n",
    "# ============================================================\n",
    "# ######################## CHANGE ME #########################\n",
    "# ============================================================\n",
    "HF_TOKEN = \"ommitted"\n",
    "TRAIN_LIMIT = 200   # max training samples (images-only subset)\n",
    "TEST_LIMIT = 20     # max held-out test samples\n",
    "# ============================================================\n",
    "# ###################### END CHANGE ME #######################\n",
    "# ============================================================\n",
    "\n",
    "login(token=HF_TOKEN)\n",
    "\n",
    "print(\"Loading derek-thomas/ScienceQA from Hugging Face...\")\n",
    "ds = load_dataset(\"derek-thomas/ScienceQA\")\n",
    "\n",
    "TRAIN_DIR = Path(\"/content/mmai-data\")\n",
    "TRAIN_IMG_DIR = TRAIN_DIR / \"images\"\n",
    "TEST_DIR = Path(\"/content/mmai-data-test\")\n",
    "TEST_IMG_DIR = TEST_DIR / \"images\"\n",
    "for d in [TRAIN_IMG_DIR, TEST_IMG_DIR]:\n",
    "    d.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "\n",
    "def build_records(split_data, images_dir, max_samples):\n",
    "    \"\"\"Filter for image-containing examples and save to disk.\"\"\"\n",
    "    records = []\n",
    "    for ex in split_data:\n",
    "        if ex[\"image\"] is None:\n",
    "            continue\n",
    "        if len(records) >= max_samples:\n",
    "            break\n",
    "\n",
    "        choices_str = \"\\n\".join(\n",
    "            f\"({chr(65 + i)}) {c}\" for i, c in enumerate(ex[\"choices\"])\n",
    "        )\n",
    "        question = f\"{ex['question']}\\n{choices_str}\"\n",
    "        answer_idx = ex[\"answer\"]\n",
    "        answer = f\"({chr(65 + answer_idx)}) {ex['choices'][answer_idx]}\"\n",
    "\n",
    "        fname = f\"img_{len(records):05d}.jpg\"\n",
    "        ex[\"image\"].convert(\"RGB\").save(str(images_dir / fname))\n",
    "\n",
    "        records.append({\n",
    "            \"image\": f\"images/{fname}\",\n",
    "            \"question\": question,\n",
    "            \"answer\": answer,\n",
    "        })\n",
    "    return records\n",
    "\n",
    "\n",
    "print(\"Processing training split...\")\n",
    "train_records = build_records(ds[\"train\"], TRAIN_IMG_DIR, TRAIN_LIMIT)\n",
    "\n",
    "print(\"Processing test split...\")\n",
    "test_records = build_records(ds[\"test\"], TEST_IMG_DIR, TEST_LIMIT)\n",
    "\n",
    "for path, recs in [(TRAIN_DIR / \"data.jsonl\", train_records),\n",
    "                    (TEST_DIR / \"data.jsonl\", test_records)]:\n",
    "    with open(path, \"w\") as f:\n",
    "        for r in recs:\n",
    "            f.write(json.dumps(r) + \"\\n\")\n",
    "\n",
    "print(f\"\\nTrain samples: {len(train_records)}  ->  {TRAIN_DIR / 'data.jsonl'}\")\n",
    "print(f\"Test  samples: {len(test_records)}   ->  {TEST_DIR / 'data.jsonl'}\")\n",
    "print(\"Done!\")"
   ]
  },
