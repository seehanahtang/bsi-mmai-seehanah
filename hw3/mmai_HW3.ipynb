    "import io\n",
    "import json\n",
    "import os\n",
    "import requests\n",
    "import torch\n",
    "from typing import Optional, Dict, Any\n",
    "from PIL import Image, UnidentifiedImageError\n",
    "from transformers import AutoProcessor, Qwen2_5_VLForConditionalGeneration\n",
    "\n",
    "\n",
    "# ============================================================\n",
    "# ######################## CHANGE ME #########################\n",
    "# ============================================================\n",
    "TEST_JSONL: str = \"/content/mmai-data-test/data.jsonl\"\n",
    "NUM_TEST_IMAGES: int = 4\n",
    "SYSTEM_PROMPTS = []\n",
    "SYSTEM_PROMPTS.append(\"You are a helpful assistant. Answer the multiple-choice question based on the image.\")\n",
    "SYSTEM_PROMPTS.append(\"You are an expert science teacher. Answer the multiple-choice question based on the image. Output ONLY the correct option letter (e.g., (A), (B)) and nothing else.\")\n",
    "SYSTEM_PROMPTS.append(\"Analyze the image step-by-step. First, identify the key objects or concepts. Second, evaluate each multiple-choice option. Finally, state the correct answer.\")\n",
    "SYSTEM_PROMPTS.append(\"You are a helpful assistant. Here is an example: If asked 'What color is the sky? (A) Blue (B) Green', you should answer '(A) Blue'. Now answer the following multiple-choice question based on the image.\")\n",
    "MAX_NEW_TOKENS: int = 256\n",
    "# ============================================================\n",
    "# ###################### END CHANGE ME #######################\n",
    "# ============================================================\n",
    "\n",
    "\n",
    "# SYSTEM CONFIG\n",
    "DO_SAMPLE: bool = False           # set True for non-greedy decoding\n",
    "TEMPERATURE: float = 1.5          # used only if DO_SAMPLE=True\n",
    "TOP_P: float = 0.3                # used only if DO_SAMPLE=True\n",
    "MODEL_ID: str = \"Qwen/Qwen2.5-VL-3B-Instruct\"\n",
    "FORCE_CPU: bool = False           # force CPU even if CUDA is available\n",
    "DTYPE_IF_GPU = torch.bfloat16     # prefer bfloat16 on recent GPUs/Colab\n",
    "DTYPE_IF_CPU = torch.float32\n",
    "\n",
    "def get_device_and_dtype() -> tuple[torch.device, torch.dtype, Optional[Dict[str, Any]]]:\n",
    "    \"\"\"Choose device/dtype and (optionally) a device_map for accelerate-style placement.\"\"\"\n",
    "    use_cuda = torch.cuda.is_available() and not FORCE_CPU\n",
    "    device = torch.device(\"cuda\") if use_cuda else torch.device(\"cpu\")\n",
    "    torch_dtype = DTYPE_IF_GPU if use_cuda else DTYPE_IF_CPU\n",
    "    device_map = \"auto\" if use_cuda else None\n",
    "    return device, torch_dtype, device_map\n",
    "\n",
    "\n",
    "def load_image(path_or_url: str) -> Image.Image:\n",
    "    \"\"\"Load a PIL Image from a local path or URL.\"\"\"\n",
    "    if path_or_url.startswith((\"http://\", \"https://\")):\n",
    "        resp = requests.get(path_or_url, timeout=30)\n",
    "        resp.raise_for_status()\n",
    "        return Image.open(io.BytesIO(resp.content)).convert(\"RGB\")\n",
    "    return Image.open(path_or_url).convert(\"RGB\")\n",
    "\n",
    "\n",
    "def build_chat_messages(image: Image.Image, question: str, prompt: str) -> list[dict]:\n",
    "    \"\"\"Create a single-turn, image+text chat for Qwen-VL processors.\"\"\"\n",
    "    return [\n",
    "        {\n",
    "            \"role\": \"system\",\n",
    "            \"content\": [\n",
    "                {\"type\": \"text\", \"text\": prompt}\n",
    "            ],\n",
    "        },\n",
    "        {\n",
    "            \"role\": \"user\",\n",
    "            \"content\": [\n",
    "                {\"type\": \"image\", \"image\": image},\n",
    "                {\"type\": \"text\", \"text\": question},\n",
    "            ],\n",
    "        }\n",
    "    ]\n",
    "\n",
    "\n",
    "def main() -> None:\n",
    "    device, torch_dtype, device_map = get_device_and_dtype()\n",
    "\n",
    "    # 1) Load model + processor\n",
    "    processor = AutoProcessor.from_pretrained(MODEL_ID)\n",
    "    model = Qwen2_5_VLForConditionalGeneration.from_pretrained(\n",
    "        MODEL_ID,\n",
    "        torch_dtype=torch_dtype,\n",
    "        device_map=device_map,\n",
    "    )\n",
    "    print(\"Model and processor loaded successfully.\")\n",
    "\n",
    "    # 2) Load test samples from JSONL\n",
    "    test_base = os.path.dirname(TEST_JSONL)\n",
    "    samples = []\n",
    "    with open(TEST_JSONL) as f:\n",
    "        for line in f:\n",
    "            if line.strip():\n",
    "                samples.append(json.loads(line))\n",
    "    samples = samples[15:15+NUM_TEST_IMAGES]\n",
    "\n",
    "    for prompt in SYSTEM_PROMPTS:\n",
    "        print(f\"Prompt: {prompt}\")\n",
    "        for ex in samples:\n",
    "          # 3) Load image (resolve relative path against JSONL dir)\n",
    "          img_path = os.path.join(test_base, ex[\"image\"])\n",
    "          image = load_image(img_path)\n",
    "\n",
    "          # 4) Build chat\n",
    "          messages = build_chat_messages(image, ex[\"question\"], prompt)\n",
    "\n",
    "          # 5) Apply chat template and preprocess\n",
    "          text = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
    "          inputs = processor(text=[text], images=[image], return_tensors=\"pt\")\n",
    "\n",
    "          # 6) Move to the right device\n",
    "          inputs = {k: v.to(model.device) for k, v in inputs.items()}\n",
    "\n",
    "          # 7) Generate\n",
    "          gen_kwargs = dict(max_new_tokens=MAX_NEW_TOKENS)\n",
    "          if DO_SAMPLE:\n",
    "              gen_kwargs.update(dict(do_sample=True, temperature=TEMPERATURE, top_p=TOP_P))\n",
    "\n",
    "          with torch.no_grad():\n",
    "              gen_ids = model.generate(**inputs, **gen_kwargs)\n",
    "\n",
    "          # 8) Decode\n",
    "          out = processor.batch_decode(gen_ids, skip_special_tokens=True)[0]\n",
    "          answer_part = out.split(\"assistant\\n\")[-1].strip() if \"assistant\\n\" in out else out.strip()\n",
    "\n",
    "          gt = ex[\"answer\"]\n",
    "          img_name = os.path.basename(ex[\"image\"])\n",
    "          match = \"OK\" if gt.split(\")\")[0].strip(\"( \") in answer_part else \"MISS\"\n",
    "          print(f\"Image: {img_name}\")\n",
    "          print(f\"Ground Truth: {gt}\")\n",
    "          print(f\"Model Output: {answer_part} [{match}]\\n\")\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
  },
